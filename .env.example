# Copy to .env and fill in your keys (or use the `env` file — both are loaded)

# DYNADOT — dynadot.com → Account → API
DYNADOT_API_KEY=

# ZAPMAIL — zapmail.ai → Settings → Integrations → API
ZAPMAIL_API_KEY=
ZAPMAIL_WORKSPACE_KEY=
ZAPMAIL_SERVICE_PROVIDER=GOOGLE

# INSTANTLY — app.instantly.ai → Settings → API Keys (used for MCP warmup)
# Export to Instantly uses your Zapmail-linked Instantly account, not this key.
INSTANTLY_API_KEY=

# SENDER IDENTITY — used when creating mailboxes
SENDER_FIRST_NAME=
SENDER_LAST_NAME=
SENDER_COMPANY=
SENDER_PHYSICAL_ADDRESS=

# Optional — if you have multiple Instantly accounts linked in Zapmail
# ZAPMAIL_INSTANTLY_THIRD_PARTY_ACCOUNT_ID=
